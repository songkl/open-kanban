# Server port (default: 8080)
PORT=8080

# Database type: sqlite or mysql (default: sqlite)
DB_TYPE=sqlite

# SQLite database file path (default: kanban.db)
DATABASE_URL=kanban.db

# MySQL database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kanban
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300

# Open Kanban Server Configuration
# Copy this file to /opt/kanban/kanban.env and customize as needed

# Server Port
PORT=8080

# Database Configuration
DB_TYPE=sqlite
DATABASE_URL=/opt/kanban/kanban.db

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com

# Web Directory (leave empty to use embedded web assets)
# WEB_DIR=/opt/kanban/web

# Logging
# LOG_LEVEL=info
